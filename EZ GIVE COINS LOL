local ReplicatedStorage = game:GetService("ReplicatedStorage")

local Rayfield = loadstring(game:HttpGet("https://sirius.menu/rayfield"))()

local Give = ReplicatedStorage:WaitForChild("Donate_Money_Remotes"):WaitForChild("Give")

local Amount = 5000
local Running = false

local Window = Rayfield:CreateWindow({
    Name = "Money Spawner",
    LoadingTitle = "Please Wait...",
    LoadingSubtitle = "I WANNA RUN AWAY TOWER SCRIPT ARE LOADING...",
    ConfigurationSaving = {
        Enabled = true,
        FolderName = "MoneySpawner",
        FileName = "Settings"
    },
    Discord = {
        Enabled = false
    },
    KeySystem = false
})

-- Main Tab
local Main = Window:CreateTab("Main", 4483362458)

-- Credits Tab
local Credits = Window:CreateTab("Credits", 4483362458)

-- Main Tab
Main:CreateSlider({
    Name = "Select Amount For Coins",
    Range = {1, 5000},
    Increment = 1,
    Suffix = "$",
    CurrentValue = Amount,
    Callback = function(Value)
        Amount = Value
    end
})

Main:CreateButton({
    Name = "Give Once",
    Callback = function()
        Give:FireServer(Amount)

        Rayfield:Notify({
            Title = "Donation Coins",
            Content = "Sent $" .. Amount,
            Duration = 3,
            Image = 4483362458
        })
    end
})

Main:CreateToggle({
    Name = "Auto Give",
    CurrentValue = false,
    Callback = function(Value)
        Running = Value

        if Running then
            task.spawn(function()
                while Running do
                    Give:FireServer(Amount)
                    task.wait(0.1)
                end
            end)
        end
    end
})

Main:CreateParagraph({
    Title = "Info",
    Content = "This Script Was Made to Let everyone from a Server Collect it and They will be Rich! :D"
})

